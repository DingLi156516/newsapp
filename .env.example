# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your-anon-key
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key

# Google Gemini (used in Phase 2c)
GEMINI_API_KEY=AIza...your-gemini-key

# Cron authentication (used in Phase 2b)
CRON_SECRET=your-random-secret-string

# Auth: No additional env vars needed — @supabase/ssr uses the same URL and anon key above.
# Configure Google OAuth in Supabase Dashboard → Authentication → Providers → Google.
